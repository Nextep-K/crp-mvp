{
  "_comment": "05_프롬프트_v_f1 운영 파생물. 실제 시스템 프롬프트 문자열은 prompts.py에 보관. 이 파일은 버전·호출 정책·그룹 메타만 관리.",
  "prompt_version": "p_f1.0",
  "call_policy": {
    "model": "claude-sonnet-4-20250514",
    "temperature": 0.3,
    "parse_retry_temperature": 0.1,
    "max_tokens": 1500,
    "ensemble_n": 3,
    "timeout_sec": 60
  },
  "item_groups": {
    "group1_qli": ["lp", "bf", "ae"],
    "group2_mti": ["q1", "q2", "ci1", "ci2", "ci3"],
    "group3_idx": ["rec", "recon", "orc"]
  },
  "item_scale": {
    "lp":    [1, 10], "bf":    [1, 10], "ae":    [1, 10],
    "q1":    [1, 10], "q2":    [1, 10],
    "ci1":   [0,  3], "ci2":   [0,  3], "ci3":   [0,  3],
    "rec":   [1, 10], "recon": [1, 10], "orc":   [1, 10]
  },
  "aux_prompts": {
    "cls_s": {
      "trigger": "class_confidence < 0.6",
      "purpose": "Class S 경계 발화 보조 판정"
    },
    "disengage": {
      "trigger": "disengagement_rulebased_flag = true",
      "purpose": "측정 회피 2차 의미 검증"
    }
  }
}
